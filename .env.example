# -------------------------------------------------------------------
# Database
# -------------------------------------------------------------------
PAYBRIDGE_DB_NAME=paybridge
PAYBRIDGE_DB_USERNAME=paybridge
PAYBRIDGE_DB_PASSWORD=paybridge

# -------------------------------------------------------------------
# Feature flags
# -------------------------------------------------------------------
PAYBRIDGE_STRIPE_ENABLED=true
PAYBRIDGE_NICEPAY_ENABLED=true
PAYBRIDGE_NICEPAY_LOCAL_ONLY=false

# -------------------------------------------------------------------
# Operator security (local/dev example values — production must override with real credentials)
# -------------------------------------------------------------------
PAYBRIDGE_OPERATOR_USERNAME=operator
PAYBRIDGE_OPERATOR_PASSWORD=operator-change-me
PAYBRIDGE_CONSOLE_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# -------------------------------------------------------------------
# Stripe
# -------------------------------------------------------------------
PAYBRIDGE_STRIPE_PROVIDER_ENABLED=true
PAYBRIDGE_STRIPE_PUBLISHABLE_KEY=
PAYBRIDGE_STRIPE_SECRET_KEY=
PAYBRIDGE_STRIPE_WEBHOOK_SECRET=
PAYBRIDGE_STRIPE_DEFAULT_CURRENCY=USD

# -------------------------------------------------------------------
# NicePay
# -------------------------------------------------------------------
PAYBRIDGE_NICEPAY_PROVIDER_ENABLED=true
PAYBRIDGE_NICEPAY_MID=
PAYBRIDGE_NICEPAY_MERCHANT_KEY=
