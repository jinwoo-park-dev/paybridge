# Copy this file to .env.prod only for local/manual testing.
# For the EC2 deployment, prefer rendering .env.prod from SSM Parameter Store
# with deploy/single-ec2/scripts/render-env-from-ssm.sh.

PAYBRIDGE_DOMAIN=paybridge-us.com
PAYBRIDGE_IMAGE=123456789012.dkr.ecr.us-east-1.amazonaws.com/paybridge:replace-with-git-sha

SPRING_PROFILES_ACTIVE=prod
JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=65 -XX:InitialRAMPercentage=25 -XX:+UseContainerSupport

PAYBRIDGE_DB_NAME=paybridge
PAYBRIDGE_DB_USERNAME=paybridge_app
PAYBRIDGE_DB_PASSWORD=replace-with-strong-password
PAYBRIDGE_DB_URL=jdbc:postgresql://postgres:5432/paybridge

PAYBRIDGE_OPERATOR_USERNAME=operator
PAYBRIDGE_OPERATOR_PASSWORD=replace-with-strong-password
PAYBRIDGE_CONSOLE_ALLOWED_ORIGINS=https://paybridge-us.com
PAYBRIDGE_OPERATOR_API_ENABLED=true

PAYBRIDGE_STRIPE_ENABLED=true
PAYBRIDGE_STRIPE_PROVIDER_ENABLED=true
PAYBRIDGE_STRIPE_PUBLISHABLE_KEY=pk_test_replace
PAYBRIDGE_STRIPE_SECRET_KEY=sk_test_replace
PAYBRIDGE_STRIPE_WEBHOOK_SECRET=whsec_replace
PAYBRIDGE_STRIPE_DEFAULT_CURRENCY=USD

PAYBRIDGE_NICEPAY_ENABLED=true
PAYBRIDGE_NICEPAY_PROVIDER_ENABLED=true
PAYBRIDGE_NICEPAY_LOCAL_ONLY=false
PAYBRIDGE_NICEPAY_MID=replace-with-test-mid
PAYBRIDGE_NICEPAY_MERCHANT_KEY=replace-with-test-merchant-key
